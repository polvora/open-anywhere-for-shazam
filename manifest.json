{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.0.0",
  "default_locale": "en",
  "description": "__MSG_ext_desc__",
  "homepage_url": "https://github.com/polvora/open-anywhere-for-shazam",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.shazam.com/*", "https://shazam.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "open-anywhere-for-shazam@marcelo",
      "strict_min_version": "115.0"
    }
  }
}
